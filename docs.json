{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "NEC 新能源开发者社区",
  "colors": {
    "primary": "#0EA5E9",
    "light": "#38BDF8",
    "dark": "#0284C7"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "文档",
        "groups": [
          {
            "group": "入门指南",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "项目模块",
            "pages": [
              "modules/overview",
              "modules/robotics",
              "modules/embedded",
              "modules/algorithms"
            ]
          },
          {
            "group": "贡献指南",
            "pages": [
              "contributing/guidelines",
              "contributing/workflow",
              "contributing/code-style"
            ]
          },
          {
            "group": "社区",
            "pages": [
              "community/about",
              "community/a416-lab",
              "community/discord"
            ]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "API 文档",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "接口示例",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Gitee 仓库",
          "href": "https://gitee.com/darrenpig/new_energy_coder_club",
          "icon": "code"
        },
        {
          "anchor": "ROBOCON 官网",
          "href": "https://www.cnrobocon.net/",
          "icon": "robot"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "问题反馈",
        "href": "https://gitee.com/darrenpig/new_energy_coder_club/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "加入社区",
      "href": "https://gitee.com/darrenpig/new_energy_coder_club"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://gitee.com/darrenpig",
      "linkedin": "https://www.linkedin.com/company/new-energy-coder"
    }
  }
}
